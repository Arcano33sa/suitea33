rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function tokenWorkspace() {
      return signedIn() && request.auth.token.workspaceId is string && request.auth.token.workspaceId.size() > 0
        ? request.auth.token.workspaceId
        : 'default';
    }

    function requesterPath(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid);
    }

    function requesterExists(workspaceId) {
      return signedIn() && exists(requesterPath(workspaceId));
    }

    function requesterData(workspaceId) {
      return get(requesterPath(workspaceId)).data;
    }

    function requesterActiveMember(workspaceId) {
      return requesterExists(workspaceId)
        && requesterData(workspaceId).status == 'active';
    }

    function requesterAdmin(workspaceId) {
      return requesterActiveMember(workspaceId)
        && requesterData(workspaceId).role == 'admin';
    }

    function requesterAgenda(workspaceId) {
      return requesterActiveMember(workspaceId)
        && (requesterData(workspaceId).role == 'admin'
          || requesterData(workspaceId).role == 'ventas');
    }

    function sameUser(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function validRole(role) {
      return role == 'admin'
        || role == 'ventas'
        || role == 'finanzas'
        || role == 'consulta';
    }

    function validStatus(status) {
      return status == 'active'
        || status == 'inactive';
    }

    function validAgendaType(type) {
      return type == 'reunion'
        || type == 'tarea'
        || type == 'compra';
    }

    function validAgendaStatus(status) {
      return status == 'pendiente'
        || status == 'hecho'
        || status == 'cancelado';
    }

    function validAgendaPriority(priority) {
      return priority == 'baja'
        || priority == 'media'
        || priority == 'alta';
    }

    function validAgendaModality(modality) {
      return modality == ''
        || modality == 'presencial'
        || modality == 'llamada'
        || modality == 'videollamada';
    }

    function validRawMaterialUnit(unit) {
      return unit == 'Unidad'
        || unit == 'Cajas'
        || unit == 'Litros'
        || unit == 'Galones';
    }

    function validRawMaterialNumber(value) {
      return value is int || value is float;
    }

    function validRawMaterialPayload(workspaceId, materialId) {
      return request.resource.data.materialId == materialId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 120
        && request.resource.data.category is string
        && request.resource.data.category.size() >= 1
        && request.resource.data.category.size() <= 80
        && validRawMaterialUnit(request.resource.data.unit)
        && validRawMaterialNumber(request.resource.data.price)
        && request.resource.data.price >= 0
        && request.resource.data.active is bool
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 300
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function validAgendaNumber(value) {
      return value == null
        || value is int
        || value is float;
    }

    function validAgendaPedido(pedido) {
      return pedido is map
        && pedido.enabled is bool
        && pedido.productId is string
        && pedido.productId.size() <= 120
        && pedido.product is string
        && pedido.product.size() <= 160
        && validAgendaNumber(pedido.price)
        && validAgendaNumber(pedido.quantity)
        && validAgendaNumber(pedido.total)
        && pedido.delivery is string
        && pedido.delivery.size() <= 10
        && (!pedido.enabled
          || (pedido.product.size() >= 2
            && pedido.delivery.size() == 10
            && validAgendaNumber(pedido.price)
            && pedido.price > 0
            && validAgendaNumber(pedido.quantity)
            && pedido.quantity > 0
            && validAgendaNumber(pedido.total)
            && pedido.total > 0));
    }

    function validAgendaPurchase(purchase) {
      return purchase is map
        && purchase.materialId is string
        && purchase.materialId.size() >= 1
        && purchase.materialId.size() <= 160
        && purchase.name is string
        && purchase.name.size() >= 1
        && purchase.name.size() <= 120
        && purchase.category is string
        && purchase.category.size() <= 80
        && validRawMaterialUnit(purchase.unit)
        && validAgendaNumber(purchase.priceUsed)
        && purchase.priceUsed >= 0
        && validAgendaNumber(purchase.quantity)
        && purchase.quantity > 0
        && validAgendaNumber(purchase.subtotal)
        && purchase.subtotal >= 0;
    }

    function validAgendaPurchaseItem(item) {
      return item is map
        && item.materialId is string
        && item.materialId.size() <= 160
        && item.name is string
        && item.name.size() >= 1
        && item.name.size() <= 120
        && item.category is string
        && item.category.size() <= 80
        && validRawMaterialUnit(item.unit)
        && validAgendaNumber(item.priceUsed)
        && item.priceUsed >= 0
        && validAgendaNumber(item.quantity)
        && item.quantity > 0
        && validAgendaNumber(item.subtotal)
        && item.subtotal >= 0;
    }

    function validAgendaPurchaseGroup(group) {
      return group is map
        && group.version is int
        && group.version >= 1
        && group.itemCount is int
        && group.itemCount >= 1
        && group.itemCount <= 100
        && validAgendaNumber(group.totalGeneral)
        && group.totalGeneral >= 0
        && group.items is list
        && group.items.size() == group.itemCount
        && group.items.size() >= 1
        && group.items.size() <= 100
        && validAgendaPurchaseItem(group.items[0]);
    }

    function validAgendaPurchaseDocument(data) {
      return ('purchaseGroup' in data && validAgendaPurchaseGroup(data.purchaseGroup))
        || ('purchase' in data && validAgendaPurchase(data.purchase));
    }

    function validAgendaPayload(workspaceId, recordId) {
      return request.resource.data.id == recordId
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.subject is string
        && request.resource.data.subject.size() >= 1
        && request.resource.data.subject.size() <= 120
        && validAgendaType(request.resource.data.type)
        && request.resource.data.client is string
        && request.resource.data.client.size() <= 120
        && (request.resource.data.type != 'reunion' || request.resource.data.client.size() >= 1)
        && request.resource.data.clientId is string
        && request.resource.data.clientId.size() <= 120
        && validAgendaModality(request.resource.data.modality)
        && request.resource.data.date is string
        && request.resource.data.date.size() == 10
        && request.resource.data.time is string
        && request.resource.data.time.size() <= 5
        && validAgendaStatus(request.resource.data.status)
        && validAgendaPriority(request.resource.data.priority)
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 1200
        && request.resource.data.createdAt is string
        && request.resource.data.createdAt.size() >= 10
        && request.resource.data.createdAt.size() <= 40
        && request.resource.data.updatedAt is string
        && request.resource.data.updatedAt.size() >= 10
        && request.resource.data.updatedAt.size() <= 40
        && request.resource.data.createdAtMs is int
        && request.resource.data.createdAtMs > 0
        && request.resource.data.updatedAtMs is int
        && request.resource.data.updatedAtMs > 0
        && request.resource.data.schemaVersion is int
        && request.resource.data.schemaVersion >= 6
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.size() <= 128
        && request.resource.data.updatedBy is string
        && request.resource.data.updatedBy.size() <= 128
        && validAgendaPedido(request.resource.data.pedido)
        && (request.resource.data.type != 'compra' || validAgendaPurchaseDocument(request.resource.data));
    }

    function validMemberPayload(workspaceId, uid) {
      return request.resource.data.uid == uid
        && request.resource.data.workspaceId == workspaceId
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 80
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 120
        && validRole(request.resource.data.role)
        && validStatus(request.resource.data.status);
    }

    match /workspaces/{workspaceId} {
      allow get: if requesterActiveMember(workspaceId) || (signedIn() && workspaceId == tokenWorkspace());
      allow list: if requesterAdmin(workspaceId);
      allow create, update, delete: if requesterAdmin(workspaceId);

      match /members/{uid} {
        allow get: if requesterAdmin(workspaceId) || (sameUser(uid) && workspaceId == tokenWorkspace());
        allow list: if requesterAdmin(workspaceId);
        allow create, update: if requesterAdmin(workspaceId) && validMemberPayload(workspaceId, uid);
        allow delete: if requesterAdmin(workspaceId);
      }

      match /rawMaterials/{materialId} {
        allow get, list: if requesterActiveMember(workspaceId);
        allow create, update: if requesterAdmin(workspaceId) && validRawMaterialPayload(workspaceId, materialId);
        allow delete: if requesterAdmin(workspaceId);
      }

      match /agendaRecords/{recordId} {
        allow get, list: if requesterAgenda(workspaceId);
        allow create, update: if requesterAgenda(workspaceId) && validAgendaPayload(workspaceId, recordId);
        allow delete: if requesterAgenda(workspaceId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
